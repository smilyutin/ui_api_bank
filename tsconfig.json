{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "playwright.config.ts",
    "config/**/*.ts",
    "enums/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "pages/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}